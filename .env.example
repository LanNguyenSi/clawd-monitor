# Required
ADMIN_PASSWORD_HASH=                # bcrypt hash: npx bcryptjs hash "yourpassword"
JWT_SECRET=                         # Random 32+ char string

# Default OpenClaw instance (can be overridden per-instance in UI)
NEXT_PUBLIC_DEFAULT_GATEWAY_URL=http://localhost:9500
DEFAULT_GATEWAY_TOKEN=              # OpenClaw API token

# Memory Viewer — path to clawd workspace (contains MEMORY.md, CURRENT.md, memory/*.md)
CLAWD_DIR=/root/.openclaw/workspace

# Agent tokens (comma-separated, one per agent)
AGENT_TOKENS=token-ice-local,token-lava-vps

# Offline agent TTL (ms, default: 300000 = 5min)
AGENT_TTL_MS=300000

# Persistent data directory (tokens, password — mount as volume)
CLAWD_MONITOR_DATA_DIR=/data
