# Runtime secrets for production deployment
# This file is loaded by docker-compose as an additional env_file.
#
# IMPORTANT: Dollar signs ($) in values must be escaped as $$ for Docker Compose.
# Example: ADMIN_PASSWORD_HASH=$$2a$$10$$xPSqjZ...
#
# Generate a bcrypt hash: node -e "require('bcryptjs').hash('password',10).then(console.log)"
# Then replace each $ with $$

ADMIN_PASSWORD_HASH=
JWT_SECRET=
